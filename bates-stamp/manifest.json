{
  "manifest_version": 3,
  "name": "Bates Numbering PDF Tool - Paralegal Toolkit",
  "version": "1.0.2",
  "author": "Lord Fernandez",
  "description": "Add Bates numbers to PDF files in your browser. Custom prefix, font, size, color, and position. Fast, local, and private.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "tabs",
    "downloads"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bates Numbering PDF Tool - Paralegal Toolkit",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "incognito": "split",
  "web_accessible_resources": [
    {
      "resources": ["lib/pdf.mjs", "lib/pdf.worker.min.mjs"],
      "matches": ["chrome-extension://*/*"]
    }
  ]
}


