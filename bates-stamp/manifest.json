{
  "manifest_version": 3,
  "name": "Paralegal Toolkit - Bates Stamp",
  "version": "1.0.2",
  "author": "Lord Fernandez",
  "description": "Free Bates stamping for PDFs. No Adobe subscription needed. All processing stays on your device.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "tabs",
    "downloads"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Paralegal Toolkit - Bates Stamp",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "incognito": "split",
  "web_accessible_resources": [
    {
      "resources": ["lib/pdf.mjs", "lib/pdf.worker.min.mjs"],
      "matches": ["chrome-extension://*/*"]
    }
  ]
}


