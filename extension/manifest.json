{
  "manifest_version": 3,
  "name": "Paralegal Toolkit — Bates Stamping",
  "version": "1.0.0",
  "description": "Bates stamp PDF documents for litigation and discovery. All processing runs on your computer; no data is sent to any server.",
  "permissions": [
    "storage",
    "contextMenus","activeTab","tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bates stamp PDF"
  },
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/pdf.mjs", "lib/pdf.worker.min.mjs"],
      "matches": ["<all_urls>"]
    }
  ]
}


