{
  "manifest_version": 3,
  "name": "Paralegal Toolkit - Bates Stamp",
  "version": "1.0.0",
  "author": "Lord Fernandez",
  "description": "Bates stamp PDF documents for litigation and legal discovery. Add sequential numbering, customize prefix and position, and save court-ready files. All processing runs locally on your computer—no data is sent to any server.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "tabs",
    "downloads"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Paralegal Toolkit - Bates Stamp",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/pdf.mjs", "lib/pdf.worker.min.mjs"],
      "matches": ["<all_urls>"]
    }
  ]
}


